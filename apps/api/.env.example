# SQLAlchemy database URL. SQLite by default; swap for PostgreSQL in production,
# e.g. postgresql+psycopg://user:pass@host:5432/repodoctor
DATABASE_URL=sqlite:///./data/repo_doctor.db

# OpenAI API key used for the AI diagnosis layer. If unset, Repo Doctor falls
# back to deterministic rule-based diagnosis grouping (clearly labeled).
OPENAI_API_KEY=

# OpenAI model for diagnosis generation
OPENAI_MODEL=gpt-4o-mini

# Root directory for isolated repository workspaces and working copies
WORKSPACE_ROOT=./data/workspaces

# Upload / clone limits
MAX_UPLOAD_SIZE_MB=100
MAX_EXTRACTED_SIZE_MB=300
MAX_FILE_COUNT=20000
CLONE_TIMEOUT_SECONDS=120

# Verification (lint/test/build) execution
COMMAND_TIMEOUT_SECONDS=180
ALLOW_DEPENDENCY_INSTALL=false

# Comma-separated list of allowed CORS origins for the frontend
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
